---
import { t } from '../../lib/i18n/store';
import Eyebrow from '../ui/Eyebrow.astro';
---

<section
  id="services"
  class="min-h-screen"
  style="padding: 110px 40px; background: #C6F24E; color: #0C0D10;"
>
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Eyebrow 05 — inverted (dark on lime) -->
    <div class="rev" style="margin-bottom: 22px;">
      <div style="display: flex; align-items: baseline; gap: 16px; font-family: var(--font-mono); font-size: 12px; font-weight: 700; letter-spacing: 2px; color: #0C0D10; text-transform: uppercase;">
        <span style="opacity: 0.5; font-size: 13px;">05</span>
        <span style="height: 1px; width: 40px; background: rgba(12,13,16,0.4); display: inline-block;"></span>
        <span data-i18n="services_label">{t('en', 'services_label')}</span>
      </div>
    </div>

    <h2
      class="rev"
      style="font-family: var(--font-display); font-size: clamp(34px, 5vw, 72px); line-height: 0.98; letter-spacing: -2px; font-weight: 700; margin: 0 0 16px; max-width: 760px; color: #0C0D10;"
      data-i18n="services_h2"
    >
      {t('en', 'services_h2')}
    </h2>

    <p
      class="rev"
      style="font-size: 17px; line-height: 1.6; max-width: 540px; margin: 0 0 46px; color: #1E2410; font-weight: 500;"
      data-i18n="services_sub"
    >
      {t('en', 'services_sub')}
    </p>

    <!-- Three service cards (dark on lime bg) -->
    <div class="rg-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">

      <!-- Service 01 -->
      <div
        class="rev"
        style="background: #101218; color: #F2F2EE; padding: 30px; box-shadow: 8px 8px 0 #0C0D10;"
      >
        <div
          class="font-mono text-lime"
          style="font-size: 32px; font-weight: 700; margin-bottom: 20px;"
        >
          01
        </div>
        <h3
          class="font-display font-bold"
          style="font-size: 21px; letter-spacing: -0.4px; margin: 0 0 12px; color: #F2F2EE;"
          data-i18n="svc1_title"
        >
          {t('en', 'svc1_title')}
        </h3>
        <p
          class="text-muted"
          style="font-size: 15px; line-height: 1.6; margin: 0;"
          data-i18n="svc1_desc"
        >
          {t('en', 'svc1_desc')}
        </p>
      </div>

      <!-- Service 02 -->
      <div
        class="rev"
        style="background: #101218; color: #F2F2EE; padding: 30px; box-shadow: 8px 8px 0 #0C0D10;"
      >
        <div
          class="font-mono text-lime"
          style="font-size: 32px; font-weight: 700; margin-bottom: 20px;"
        >
          02
        </div>
        <h3
          class="font-display font-bold"
          style="font-size: 21px; letter-spacing: -0.4px; margin: 0 0 12px; color: #F2F2EE;"
          data-i18n="svc2_title"
        >
          {t('en', 'svc2_title')}
        </h3>
        <p
          class="text-muted"
          style="font-size: 15px; line-height: 1.6; margin: 0;"
          data-i18n="svc2_desc"
        >
          {t('en', 'svc2_desc')}
        </p>
      </div>

      <!-- Service 03 -->
      <div
        class="rev"
        style="background: #101218; color: #F2F2EE; padding: 30px; box-shadow: 8px 8px 0 #0C0D10;"
      >
        <div
          class="font-mono text-lime"
          style="font-size: 32px; font-weight: 700; margin-bottom: 20px;"
        >
          03
        </div>
        <h3
          class="font-display font-bold"
          style="font-size: 21px; letter-spacing: -0.4px; margin: 0 0 12px; color: #F2F2EE;"
          data-i18n="svc3_title"
        >
          {t('en', 'svc3_title')}
        </h3>
        <p
          class="text-muted"
          style="font-size: 15px; line-height: 1.6; margin: 0;"
          data-i18n="svc3_desc"
        >
          {t('en', 'svc3_desc')}
        </p>
      </div>

    </div>

    <!-- CTA -->
    <div class="rev" style="margin-top: 34px;">
      <a
        href="#contact"
        style="display: inline-flex; align-items: center; gap: 10px; padding: 16px 28px; background: #0C0D10; color: #C6F24E; font-weight: 700; font-size: 16px; box-shadow: 6px 6px 0 rgba(12,13,16,0.35); font-family: var(--font-display);"
        data-i18n="svc_cta"
      >
        {t('en', 'svc_cta')}
        <span class="font-mono" aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>
