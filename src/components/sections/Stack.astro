---
import { t } from '../../lib/i18n/store';
import Eyebrow from '../ui/Eyebrow.astro';

const aiChips = [
  'Claude Code', 'MCP', 'Subagents', 'Evals & Verification',
  'RAG', 'Structured Output', 'OpenAI', 'Anthropic', 'OpenRouter',
  'Ollama', 'LangChain',
];

const backendSkills = [
  'Node.js', 'NestJS', 'PHP', 'Python', 'REST APIs',
  'PostgreSQL', 'MySQL', 'Redis', 'Supabase',
];

const frontendSkills = [
  'React', 'React Native', 'Next.js', 'TypeScript', 'Astro', 'Tailwind CSS',
];

const infraSkills = [
  'AWS (EC2, S3, Lambda)', 'Docker', 'Vercel', 'GitHub Actions',
  'Cloudflare', 'Linux', 'Nginx', 'Git',
];
---

<section
  id="skills"
  class="min-h-screen bg-panel"
  style="padding: 110px 40px;"
>
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Eyebrow 03 -->
    <div class="rev" style="margin-bottom: 22px;">
      <Eyebrow index="03" data-i18n="skills_label">{t('en', 'skills_label')}</Eyebrow>
    </div>

    <h2
      class="rev font-display font-bold text-ink"
      style="font-size: clamp(32px, 4.8vw, 64px); line-height: 1.0; letter-spacing: -2px; margin: 0 0 16px; max-width: 820px;"
      data-i18n="skills_h2"
    >
      {t('en', 'skills_h2')}
    </h2>

    <p
      class="rev text-muted"
      style="font-size: 17px; line-height: 1.6; max-width: 580px; margin: 0 0 46px;"
      data-i18n="skills_sub"
    >
      {t('en', 'skills_sub')}
    </p>

    <!-- Featured AI block — lime border -->
    <div
      class="rev"
      style="border: 2px solid #C6F24E; background: linear-gradient(160deg, rgba(198,242,78,0.10), rgba(198,242,78,0.02)); padding: 36px; margin-bottom: 18px; position: relative; box-shadow: 10px 10px 0 rgba(198,242,78,0.18);"
    >
      <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
        <!-- Left: title + desc -->
        <div style="max-width: 600px;">
          <div
            class="font-mono text-lime"
            style="font-size: 12px; letter-spacing: 1px; margin-bottom: 12px;"
          >
            ★ <span data-i18n="skills_core">{t('en', 'skills_core')}</span>
          </div>
          <h3
            class="font-display font-bold text-ink"
            style="font-size: clamp(24px, 3vw, 34px); letter-spacing: -1px; margin: 0 0 14px;"
            data-i18n="skills_ai_title"
          >
            {t('en', 'skills_ai_title')}
          </h3>
          <p
            class="text-muted"
            style="font-size: 16px; line-height: 1.65; margin: 0;"
            data-i18n="skills_ai_desc"
          >
            {t('en', 'skills_ai_desc')}
          </p>
        </div>

        <!-- Right: mono agent-loop diagram -->
        <div
          class="font-mono text-lime"
          style="font-size: 13px; line-height: 1.95; background: rgba(12,13,16,0.5); border: 1px solid #2C3326; padding: 14px 18px;"
        >
          <div class="text-faint" style="font-size: 10px; letter-spacing: 1px; margin-bottom: 8px;">
            // <span data-i18n="skills_loop">{t('en', 'skills_loop')}</span>
          </div>
          user → agent<br />
          &nbsp;&nbsp;↳ context · tools<br />
          &nbsp;&nbsp;↳ act · verify<br />
          &nbsp;&nbsp;↳ iterate ↻<br />
          <span class="text-ink">→ shipped ✓</span>
        </div>
      </div>

      <!-- AI skill chips -->
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px;">
        {aiChips.map((chip) => (
          <span
            class="font-mono"
            style="padding: 9px 15px; border: 1.5px solid #C6F24E; background: rgba(198,242,78,0.10); color: #DDF59A; font-size: 13px; font-weight: 500;"
          >
            {chip}
          </span>
        ))}
      </div>
    </div>

    <!-- Three category cards -->
    <div class="rg-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;">

      <!-- Backend -->
      <div class="rev bg-surface" style="border: 1px solid #23252D; padding: 26px;">
        <div
          class="font-mono text-lime"
          style="font-size: 12px; letter-spacing: 1px; margin-bottom: 18px;"
          data-i18n="cat_backend"
        >
          {t('en', 'cat_backend')}
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          {backendSkills.map((s) => (
            <span
              class="font-mono"
              style="padding: 7px 12px; border: 1px solid #34373F; color: #C8C8C0; font-size: 12.5px;"
            >
              {s}
            </span>
          ))}
        </div>
      </div>

      <!-- Frontend -->
      <div class="rev bg-surface" style="border: 1px solid #23252D; padding: 26px;">
        <div
          class="font-mono text-lime"
          style="font-size: 12px; letter-spacing: 1px; margin-bottom: 18px;"
          data-i18n="cat_frontend"
        >
          {t('en', 'cat_frontend')}
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          {frontendSkills.map((s) => (
            <span
              class="font-mono"
              style="padding: 7px 12px; border: 1px solid #34373F; color: #C8C8C0; font-size: 12.5px;"
            >
              {s}
            </span>
          ))}
        </div>
      </div>

      <!-- Infra & Tools -->
      <div class="rev bg-surface" style="border: 1px solid #23252D; padding: 26px;">
        <div
          class="font-mono text-lime"
          style="font-size: 12px; letter-spacing: 1px; margin-bottom: 18px;"
          data-i18n="cat_infra"
        >
          {t('en', 'cat_infra')}
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          {infraSkills.map((s) => (
            <span
              class="font-mono"
              style="padding: 7px 12px; border: 1px solid #34373F; color: #C8C8C0; font-size: 12.5px;"
            >
              {s}
            </span>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
