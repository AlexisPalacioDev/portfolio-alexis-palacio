---
import { t } from '../../lib/i18n/store';
import { Image } from 'astro:assets';
import Eyebrow from '../ui/Eyebrow.astro';
import { work, pick } from '../../lib/data/work';
import { computeSlot, buildCardTransform } from '../../lib/deck/slot';
import ProjectDeck from '../islands/ProjectDeck.astro';

// SSR active index — always 0 at build time. WU-4 island takes over at runtime.
const ACTIVE = 0;
const N = work.length;

// Default language for SSR render
const LANG = 'en' as const;

// Active item for the detail panel
const activeItem = work[ACTIVE];
---

<section
  id="projects"
  class="min-h-screen bg-panel"
  style="padding: 80px 40px; border-top: 1px solid #23252D;"
>
  <div style="width: 100%; max-width: 1280px; margin: 0 auto;">

    <!-- Eyebrow 04 -->
    <div class="rev" style="margin-bottom: 22px;">
      <Eyebrow index="04" data-i18n="projects_label">{t('en', 'projects_label')}</Eyebrow>
    </div>

    <h2
      class="rev font-display font-bold text-ink"
      style="font-size: clamp(34px, 5vw, 72px); line-height: 0.98; letter-spacing: -2px; margin: 0 0 16px; max-width: 880px;"
      data-i18n="projects_h2"
    >
      {t('en', 'projects_h2')}
    </h2>

    <p
      class="rev text-muted"
      style="font-size: 17px; line-height: 1.6; max-width: 600px; margin: 0 0 50px;"
      data-i18n="projects_sub"
    >
      {t('en', 'projects_sub')}
    </p>

    <!-- ════ DESKTOP: detail panel (left) + 3D card deck (right) ════ -->
    <!-- Hidden on phones (≤767px) where the deck interaction doesn't work;
         the mobile swipe carousel below replaces it. -->
    <div class="work-desktop">
    <!-- align-items: start keeps the two columns INDEPENDENT — the deck (right)
         no longer re-centers when the left detail panel changes height between
         projects, so the cards / arrows / dots stay put. -->
    <div class="rg-2-deck" style="display: grid; grid-template-columns: 1fr 600px; gap: 48px; align-items: start;">

      <!-- ── LEFT: Detail panel ── -->
      <div class="rev" id="work-detail">

        <!-- Company · Period · Status -->
        <div
          class="font-mono text-lime"
          style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; font-size: 12px; letter-spacing: 1px; margin-bottom: 14px;"
        >
          <span id="detail-company">{activeItem.company}</span>
          <span style="color: #3A3D47;">·</span>
          <span class="text-muted" id="detail-period">{pick(activeItem.period, LANG)}</span>
          <span
            class="font-mono bg-surface"
            style="padding: 3px 9px; border: 1px solid #2C2F38; color: #93938B; font-size: 10px; font-weight: 700;"
            id="detail-status"
          >
            {pick(activeItem.status, LANG)}
          </span>
        </div>

        <!-- Role -->
        <div
          class="font-mono text-faint"
          style="font-size: 12px; margin-bottom: 6px;"
          id="detail-role"
        >
          {pick(activeItem.role, LANG)}
        </div>

        <!-- Project name -->
        <h3
          class="font-display font-bold text-ink"
          style="font-size: clamp(30px, 4vw, 50px); line-height: 1.0; letter-spacing: -1.5px; margin: 0 0 6px;"
          id="detail-name"
        >
          {activeItem.name}
        </h3>

        <!-- Kind — colored by accent -->
        <div
          class="font-mono font-bold"
          style={`font-size: 13px; margin-bottom: 22px; color: ${activeItem.accent};`}
          id="detail-kind"
        >
          {pick(activeItem.kind, LANG)}
        </div>

        <!-- Description -->
        <p
          class="text-muted"
          style="font-size: 16.5px; line-height: 1.7; margin: 0 0 22px; max-width: 560px;"
          id="detail-desc"
        >
          {pick(activeItem.desc, LANG)}
        </p>

        <!-- Bullets -->
        <ul
          style="margin: 0 0 24px; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 10px;"
          id="detail-bullets"
        >
          {pick(activeItem.bullets, LANG).slice(0, 3).map((bullet) => (
            <li
              class="text-muted"
              style="display: flex; gap: 12px; font-size: 15px; line-height: 1.55;"
            >
              <span class="font-mono text-lime" aria-hidden="true">▹</span>
              {bullet}
            </li>
          ))}
        </ul>

        <!-- Tags -->
        <div
          style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 26px;"
          id="detail-tags"
        >
          {activeItem.tags.map((tag) => (
            <span
              class="font-mono"
              style="padding: 5px 11px; border: 1px solid #34373F; color: #C8C8C0; font-size: 11.5px;"
            >
              {tag}
            </span>
          ))}
        </div>

        <!-- Action links -->
        <div style="display: flex; flex-wrap: wrap; gap: 12px;" id="detail-links">
          {activeItem.links.link && (
            <a
              href={activeItem.links.link}
              target="_blank"
              rel="noopener noreferrer"
              class="font-display font-bold text-bg bg-lime shadow-hard-sm"
              style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; font-size: 14px;"
              data-i18n="projects_view"
            >
              {t('en', 'projects_view')}
              <span class="font-mono" aria-hidden="true">↗</span>
            </a>
          )}
          {activeItem.links.code && (
            <a
              href={activeItem.links.code}
              target="_blank"
              rel="noopener noreferrer"
              class="font-display font-bold text-ink"
              style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; font-size: 14px; border: 1px solid #34373F;"
              data-i18n="projects_code"
            >
              {t('en', 'projects_code')}
              <span class="font-mono" aria-hidden="true">↗</span>
            </a>
          )}
        </div>

      </div>
      <!-- /detail panel -->

      <!-- ── RIGHT: Card deck (SSR static fan) ── -->
      <div class="rev" id="work-deck-root">

        <!-- Deck container — landscape 5:3 cards. Size is driven by --card-w/--card-h
             so a media query can shrink the whole deck on small screens. -->
        <div
          id="work-deck"
          style="position: relative; --card-w: 460px; --card-h: 276px; height: calc(var(--card-h) + 96px); width: var(--card-w); margin: 0 auto;"
          data-active="0"
          data-count={N}
        >
          {work.map((item, i) => {
            const geo = computeSlot(i, ACTIVE, N);
            const transform = buildCardTransform(geo);
            const isVisible = !geo.hidden;
            return (
              <div
                class="work-card"
                role="button"
                data-index={i}
                style={[
                  'position: absolute;',
                  'top: 50%; left: 50%;',
                  'width: var(--card-w); height: var(--card-h);',
                  `transform: translate(-50%, -50%) ${transform};`,
                  `z-index: ${geo.zIndex};`,
                  `transition: transform .55s cubic-bezier(.2,.7,.2,1), opacity .4s ease, box-shadow .35s ease, border-color .3s ease;`,
                  `will-change: transform;`,
                  isVisible ? 'opacity: 1; pointer-events: auto;' : 'opacity: 0; pointer-events: none;',
                  `border: 1px solid ${geo.isFront ? '#C6F24E' : '#2C2F38'};`,
                  `box-shadow: ${geo.isFront ? '0 24px 60px rgba(0,0,0,0.55)' : '0 12px 30px rgba(0,0,0,0.4)'};`,
                  'background: #14151A;',
                  'cursor: pointer;',
                  'overflow: hidden;',
                  'backface-visibility: hidden;',
                ].join(' ')}
                aria-label={`Project: ${item.name} — ${pick(item.kind, LANG)}`}
                tabindex={isVisible ? '0' : '-1'}
              >
                <!-- Full project preview — 5:3 frame matches the cover art exactly, no crop -->
                <Image
                  src={item.cover}
                  alt={`${item.name} — ${pick(item.kind, LANG)}`}
                  width={460}
                  height={276}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block;"
                />
                <!-- Thin accent bar (bottom) — the only chrome; everything else lives in the panel -->
                <div
                  style={`position: absolute; left: 0; bottom: 0; width: 100%; height: 4px; background: ${item.accent};`}
                ></div>
                <!-- Hover-reveal "Open" banner — opens the live project from the card -->
                {item.links.link && (
                  <a
                    class="work-card-open"
                    href={item.links.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    tabindex={isVisible ? '0' : '-1'}
                    aria-label={`Open ${item.name}`}
                  >
                    <span data-i18n="projects_view">{t('en', 'projects_view')}</span>
                    <span class="font-mono" aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            );
          })}
        </div>

        <!-- Navigation: prev arrow · indicator dots · next arrow -->
        <div style="display: flex; align-items: center; justify-content: center; gap: 18px; margin-top: 30px;">
          <button
            id="work-prev"
            class="work-arrow font-mono"
            aria-label="Previous project"
            style="width: 40px; height: 40px; display: grid; place-items: center; border: 1px solid #34373F; background: #14151A; color: #F2F2EE; font-size: 18px; cursor: pointer; transition: border-color .25s ease, background .25s ease, color .25s ease;"
          >‹</button>

          <div
            id="work-dots"
            style="display: flex; gap: 8px; justify-content: center;"
            role="tablist"
            aria-label="Project selector"
          >
            {work.map((item, i) => {
              const isActive = i === ACTIVE;
              return (
                <button
                  class="work-dot"
                  data-index={i}
                  role="tab"
                  aria-selected={isActive ? 'true' : 'false'}
                  aria-label={`Select project: ${item.name}`}
                  style={[
                    'width: 8px; height: 8px; border-radius: 50%; border: none; cursor: pointer; padding: 0;',
                    `background: ${isActive ? '#C6F24E' : '#2C2F38'};`,
                    `transform: ${isActive ? 'scale(1.25)' : 'scale(1)'};`,
                    'transition: background .3s ease, transform .3s ease;',
                  ].join(' ')}
                />
              );
            })}
          </div>

          <button
            id="work-next"
            class="work-arrow font-mono"
            aria-label="Next project"
            style="width: 40px; height: 40px; display: grid; place-items: center; border: 1px solid #34373F; background: #14151A; color: #F2F2EE; font-size: 18px; cursor: pointer; transition: border-color .25s ease, background .25s ease, color .25s ease;"
          >›</button>
        </div>

      </div>
      <!-- /deck -->

    </div>
    <!-- /grid -->
    </div>
    <!-- /work-desktop -->

    <!-- ════ MOBILE: horizontal swipe carousel (one project per slide) ════ -->
    <div class="work-mobile">
      <div class="work-carousel">
        {work.map((item) => (
          <article class="work-slide" data-link={item.links.link ?? ''} data-code={item.links.code ?? ''}>
            <!-- Preview -->
            <div style="position: relative; aspect-ratio: 5 / 3; overflow: hidden; border: 1px solid #2C2F38; background: #14151A;">
              <Image
                src={item.cover}
                alt={`${item.name} — ${pick(item.kind, LANG)}`}
                width={460}
                height={276}
                loading="lazy"
                style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
              />
              <span
                class="font-mono text-lime"
                style="position: absolute; top: 12px; left: 12px; padding: 5px 10px; background: rgba(12,13,16,0.8); font-size: 10px; font-weight: 700; border: 1px solid #34373F;"
                data-en={pick(item.status, 'en')}
                data-es={pick(item.status, 'es')}
              >
                {pick(item.status, LANG)}
              </span>
              <div style={`position: absolute; left: 0; bottom: 0; width: 100%; height: 4px; background: ${item.accent};`}></div>
            </div>

            <!-- Meta -->
            <div
              class="font-mono"
              style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center; font-size: 11px; margin-top: 16px; color: #93938B;"
            >
              <span class="text-lime">{item.company}</span>
              <span>·</span>
              <span data-en={pick(item.period, 'en')} data-es={pick(item.period, 'es')}>{pick(item.period, LANG)}</span>
            </div>

            <h3 class="font-display font-bold text-ink" style="font-size: 30px; letter-spacing: -1px; margin: 8px 0 2px;">
              {item.name}
            </h3>
            <div
              class="font-mono font-bold"
              style={`font-size: 12.5px; color: ${item.accent}; margin-bottom: 6px;`}
              data-en={pick(item.kind, 'en')}
              data-es={pick(item.kind, 'es')}
            >
              {pick(item.kind, LANG)}
            </div>
            <div class="font-mono text-faint" style="font-size: 11px; margin-bottom: 12px;" data-en={pick(item.role, 'en')} data-es={pick(item.role, 'es')}>
              {pick(item.role, LANG)}
            </div>

            <p class="text-muted" style="font-size: 14.5px; line-height: 1.6; margin: 0 0 14px;" data-en={pick(item.desc, 'en')} data-es={pick(item.desc, 'es')}>
              {pick(item.desc, LANG)}
            </p>

            <!-- Tags -->
            <div style="display: flex; flex-wrap: wrap; gap: 7px;">
              {item.tags.slice(0, 5).map((tag) => (
                <span class="font-mono" style="padding: 4px 9px; border: 1px solid #34373F; color: #C8C8C0; font-size: 10.5px;">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <!-- Single action button — its target follows whichever slide is in front,
           so it stays in one place instead of one button per card. -->
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-top: 20px; min-height: 46px;">
        <a
          id="work-open"
          href={work[0].links.link ?? '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="font-display font-bold work-open-btn is-view"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; font-size: 14px;"
        >
          <span id="work-open-label">{t('en', 'projects_view')}</span>
          <span class="font-mono" aria-hidden="true">↗</span>
        </a>
        <span class="font-mono text-faint" style="font-size: 11px; letter-spacing: 1px;">
          ‹ <span data-en="swipe" data-es="deslizá">swipe</span> ›
        </span>
      </div>
    </div>
    <!-- /work-mobile -->

    <!-- Earlier work footnote -->
    <div class="rev" style="margin-top: 44px; display: flex; align-items: center; gap: 18px; flex-wrap: wrap;">
      <a
        href="https://github.com/AlexisPalacioDev?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono font-bold text-ink"
        style="display: inline-flex; align-items: center; gap: 10px; padding: 14px 24px; border: 1px solid #34373F; font-size: 13px;"
      >
        GitHub → AlexisPalacioDev <span aria-hidden="true">↗</span>
      </a>
      <span
        class="font-mono text-faint"
        style="font-size: 12px;"
        data-i18n="work_earlier"
      >
        {t('en', 'work_earlier')}
      </span>
    </div>

  </div>
</section>

<!--
  ProjectDeck island: attaches click handlers, indicator dot handlers, and
  wires the lang-reactive detail panel. The SSR static fan above is already
  correctly rendered (active=0) so there is no hydration pop-in.
  Data is supplied via the JSON embed below (avoids re-importing ESM modules
  client-side on the static build).
-->
<ProjectDeck />

<script
  type="application/json"
  id="work-data"
  set:html={JSON.stringify(work.map((item, i) => ({
    id: item.id,
    index: i,
    company: item.company,
    name: item.name,
    accent: item.accent,
    links: item.links,
    statusKey: item.statusKey,
    period: item.period,
    role: item.role,
    kind: item.kind,
    status: item.status,
    desc: item.desc,
    bullets: item.bullets,
    tags: item.tags,
  })))}
></script>

<script>
  // Mobile carousel: a single action button whose target + state follow the
  // slide currently in front. Switches between "Open" (live link, lime) and
  // "Code" (repo only, outline) with an animated transition.
  import { $lang } from '../../lib/i18n/store';
  import { I18N } from '../../lib/i18n/dictionary';

  const carousel = document.querySelector<HTMLElement>('.work-carousel');
  const openBtn = document.getElementById('work-open') as HTMLAnchorElement | null;
  const openLabel = document.getElementById('work-open-label');

  if (carousel && openBtn && openLabel) {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.work-slide'));
    let active: HTMLElement | null = slides[0] ?? null;
    let lastKey = '';

    function render(animate: boolean): void {
      if (!active || !openBtn || !openLabel) return;
      const link = active.dataset.link || '';
      const code = active.dataset.code || '';
      const href = link || code;
      const isCode = !link && !!code;
      const dict = $lang.get() === 'es' ? I18N.es : I18N.en;

      if (!href) {
        openBtn.style.visibility = 'hidden';
        return;
      }
      openBtn.style.visibility = 'visible';
      openBtn.href = href;
      openBtn.classList.toggle('is-code', isCode);
      openBtn.classList.toggle('is-view', !isCode);
      openLabel.textContent = isCode ? dict.projects_code : dict.projects_view;

      // Re-trigger the label swap animation only when the state actually changed.
      const key = `${href}|${$lang.get()}`;
      if (animate && key !== lastKey) {
        openBtn.classList.remove('swapping');
        void openBtn.offsetWidth; // force reflow so the animation restarts
        openBtn.classList.add('swapping');
      }
      lastKey = key;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
            active = entry.target as HTMLElement;
            render(true);
          }
        }
      },
      { root: carousel, threshold: [0.6] }
    );
    slides.forEach((s) => observer.observe(s));

    $lang.subscribe(() => render(false));
    render(false);
  }
</script>
