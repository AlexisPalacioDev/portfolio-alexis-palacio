---
import { t } from '../../lib/i18n/store';
import Eyebrow from '../ui/Eyebrow.astro';

// The four pillars of harness engineering — each maps to a title/desc i18n key.
const pillars = [
  { n: '01', titleKey: 'harness_p1_title', descKey: 'harness_p1_desc' },
  { n: '02', titleKey: 'harness_p2_title', descKey: 'harness_p2_desc' },
  { n: '03', titleKey: 'harness_p3_title', descKey: 'harness_p3_desc' },
  { n: '04', titleKey: 'harness_p4_title', descKey: 'harness_p4_desc' },
] as const;
---

<section
  id="method"
  class="min-h-screen"
  style="padding: 110px 40px; border-top: 1px solid #23252D;"
>
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Eyebrow 02 -->
    <div class="rev" style="margin-bottom: 22px;">
      <Eyebrow index="02" data-i18n="harness_label">{t('en', 'harness_label')}</Eyebrow>
    </div>

    <h2
      class="rev font-display font-bold text-ink"
      style="font-size: clamp(32px, 4.8vw, 64px); line-height: 1.0; letter-spacing: -2px; margin: 0 0 16px; max-width: 820px;"
      data-i18n="harness_h2"
    >
      {t('en', 'harness_h2')}
    </h2>

    <p
      class="rev text-muted"
      style="font-size: 17px; line-height: 1.65; max-width: 640px; margin: 0 0 46px;"
      data-i18n="harness_sub"
    >
      {t('en', 'harness_sub')}
    </p>

    <!-- Four pillar cards -->
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(232px, 1fr)); gap: 14px;"
    >
      {pillars.map((p) => (
        <div
          class="rev bg-surface"
          style="border: 1px solid #23252D; border-left: 2px solid #C6F24E; padding: 26px 24px;"
        >
          <div
            class="font-mono text-lime"
            style="font-size: 30px; font-weight: 700; line-height: 1; margin-bottom: 18px;"
          >
            {p.n}
          </div>
          <h3
            class="font-display font-bold text-ink"
            style="font-size: 19px; letter-spacing: -0.4px; margin: 0 0 10px;"
            data-i18n={p.titleKey}
          >
            {t('en', p.titleKey)}
          </h3>
          <p
            class="text-muted"
            style="font-size: 14.5px; line-height: 1.6; margin: 0;"
            data-i18n={p.descKey}
          >
            {t('en', p.descKey)}
          </p>
        </div>
      ))}
    </div>

    <!-- Closing punch line -->
    <p
      class="rev font-display font-bold text-lime"
      style="font-size: clamp(20px, 2.6vw, 30px); line-height: 1.25; letter-spacing: -0.6px; max-width: 880px; margin: 40px 0 0;"
      data-i18n="harness_close"
    >
      {t('en', 'harness_close')}
    </p>

  </div>
</section>
