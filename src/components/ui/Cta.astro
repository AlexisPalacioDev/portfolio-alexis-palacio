---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  download?: string | boolean;
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  download,
  target,
  rel,
  class: className,
} = Astro.props;
---

{
  variant === 'primary' ? (
    <a
      href={href}
      download={download}
      target={target}
      rel={rel}
      class:list={[
        'inline-block px-6 py-3 bg-lime text-bg font-display font-bold shadow-hard',
        'transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0',
        className,
      ]}
    >
      <slot />
    </a>
  ) : (
    <a
      href={href}
      download={download}
      target={target}
      rel={rel}
      class:list={[
        'inline-block px-6 py-3 border border-ink text-ink font-display font-bold',
        'transition-all duration-200 hover:border-lime hover:text-lime active:translate-y-0',
        className,
      ]}
    >
      <slot />
    </a>
  )
}
