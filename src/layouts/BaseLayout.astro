---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';
import LangToggle from '../components/islands/LangToggle.astro';
import { t } from '../lib/i18n/store';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

// Single source of truth for the site origin (used by canonical, OG, JSON-LD).
// ⚠️ Set this to the real production domain before launch.
const SITE = 'https://alexispalacio.dev';

const {
  title = 'Alexis Palacio — AI Engineer & Lead Fullstack Developer',
  description = 'Alexis Palacio — freelance full-stack developer & AI engineer in Medellín, Colombia. Available for remote work, full-time or by project: Next.js, React, TypeScript, NestJS and AI orchestration. Hire me to ship real products.',
  ogImage = '/og-image.png',
  canonical = `${SITE}/`,
} = Astro.props;

const ogTitle = title;
const ogDescription = description;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;

const keywords = [
  // identity + role
  'Alexis Palacio', 'AI Engineer', 'Lead Fullstack Developer', 'Full-Stack Developer',
  // recruiter searches (EN)
  'freelance full-stack developer', 'remote full-stack developer', 'hire full-stack developer',
  'freelance developer', 'remote developer', 'full-stack engineer for hire',
  // recruiter searches (ES)
  'desarrollador full stack', 'desarrollador full stack remoto', 'programador remoto',
  'desarrollador freelance', 'contratar desarrollador full stack', 'programador full stack',
  // specialties + stack
  'AI orchestration', 'LLM agents', 'automation', 'Next.js', 'React', 'React Native',
  'TypeScript', 'NestJS', 'Medellín', 'Colombia',
].join(', ');

// JSON-LD structured data — tells Google this is Alexis Palacio's portfolio
// (rich results + helps rank for his name and role).
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${SITE}/#alexis`,
      name: 'Alexis Palacio',
      alternateName: 'AlexisPalacioDev',
      url: `${SITE}/`,
      image: ogImageAbsolute,
      jobTitle: 'AI Engineer & Lead Fullstack Developer',
      description: 'AI orchestration, agents, automation and full-stack development.',
      email: 'mailto:alexis26-93@live.com',
      telephone: '+573206088114',
      address: { '@type': 'PostalAddress', addressLocality: 'Medellín', addressCountry: 'CO' },
      worksFor: { '@type': 'Organization', name: 'anai', url: 'https://anaiapp.ai' },
      knowsAbout: [
        'AI orchestration', 'LLM agents', 'Automation', 'Next.js', 'React',
        'React Native', 'TypeScript', 'NestJS', 'Full-stack development',
      ],
      sameAs: [
        'https://github.com/AlexisPalacioDev',
        'https://www.linkedin.com/in/poisoneddog/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'Alexis Palacio — Portfolio',
      description: ogDescription,
      inLanguage: ['en', 'es'],
      publisher: { '@id': `${SITE}/#alexis` },
    },
  ],
};

// Single source of truth for the nav — rendered into both the desktop bar and
// the mobile dropdown so the two can't drift apart.
const navItems = [
  { href: '#about', key: 'nav_about' },
  { href: '#skills', key: 'nav_skills' },
  { href: '#projects', key: 'nav_projects' },
  { href: '#services', key: 'nav_services' },
  // { href: '#testimonials', key: 'nav_testimonials' }, // hidden — see index.astro
  { href: '#contact', key: 'nav_contact' },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Alexis Palacio" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0C0D10" />
    <meta name="geo.region" content="CO-ANT" />
    <meta name="geo.placename" content="Medellín, Colombia" />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Alexis Palacio — AI Engineer & Lead Fullstack Developer" />
    <meta property="og:site_name" content="Alexis Palacio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="es_ES" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content="Alexis Palacio — AI Engineer & Lead Fullstack Developer" />
    <meta name="twitter:creator" content="@AlexisPalacioDev" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      No-FOUC: read persisted lang from localStorage before first paint
      and set html[lang] + data-lang so apply.ts can swap on load.
      $lang (persistentAtom) uses the key 'lang' — must match here.
    -->
    <script is:inline>
      (function () {
        try {
          var lang = localStorage.getItem('lang');
          if (lang === 'es') {
            document.documentElement.lang = 'es';
            document.documentElement.setAttribute('data-lang', 'es');
          }
        } catch (_) {}
      })();
    </script>

    <!-- Structured data (JSON-LD): Person + WebSite for rich results & ranking -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="bg-bg text-ink font-display" style="-webkit-font-smoothing: antialiased; overflow-x: hidden;">

    <!-- Skip to main content — a11y: allows keyboard/screen-reader users to bypass nav -->
    <a href="#home" class="skip-link">Skip to main content</a>

    <!--
      3px lime scroll-progress bar — positioned at the absolute top of the viewport.
      Width is driven by scroll position; the RAF behavior is wired in WU-4 (scrollProgress.ts).
      The DOM element ships here so it exists in the initial HTML before hydration.
    -->
    <div
      id="scroll-progress"
      aria-hidden="true"
      style="position: fixed; top: 0; left: 0; height: 3px; width: 0%; background: #C6F24E; z-index: 60; box-shadow: 0 0 10px rgba(198,242,78,0.7); pointer-events: none;"
    ></div>

    <!-- Fixed navigation bar -->
    <nav
      class="fixed left-0 right-0 z-50 flex items-center justify-between"
      style="top: 3px; padding: 14px 34px; background: rgba(12,13,16,0.78); backdrop-filter: blur(12px); border-bottom: 1px solid #23252D;"
      aria-label="Primary navigation"
    >
      <!-- AP monogram + logotype -->
      <a
        href="#home"
        style="display: flex; align-items: center; gap: 12px; text-decoration: none;"
        aria-label="Alexis Palacio — back to top"
      >
        <span
          class="font-mono font-bold text-bg bg-lime"
          style="display: grid; place-items: center; width: 38px; height: 38px; font-size: 17px; box-shadow: 3px 3px 0 #3D5BFF; letter-spacing: -0.5px;"
        >
          AP
        </span>
        <span
          class="font-mono text-muted hidden md:block"
          style="font-size: 12px; font-weight: 500; letter-spacing: 1px; line-height: 1.4;"
        >
          ALEXIS<br />PALACIO
        </span>
      </a>

      <!-- Nav anchor links -->
      <ul
        class="hidden md:flex items-center gap-6 font-mono"
        style="font-size: 12.5px; letter-spacing: 0.4px; color: #93938B;"
        role="list"
      >
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link hover:text-lime"
              style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
              data-i18n={item.key}
            >
              {t('en', item.key)}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right cluster: language toggle + mobile menu button -->
      <div style="display: flex; align-items: center; gap: 14px;">
        <LangToggle />
        <button
          id="nav-toggle"
          class="md:hidden font-mono"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          style="width: 40px; height: 38px; display: grid; place-items: center; background: transparent; border: 1px solid #34373F; color: #F2F2EE; font-size: 18px; cursor: pointer; line-height: 1;"
        >
          <span id="nav-toggle-icon" aria-hidden="true">☰</span>
        </button>
      </div>
    </nav>

    <!-- Mobile dropdown menu (only rendered/visible below md) -->
    <div
      id="mobile-menu"
      class="md:hidden"
      hidden
      style="position: fixed; top: 72px; left: 0; right: 0; z-index: 49; background: rgba(12,13,16,0.97); backdrop-filter: blur(14px); border-bottom: 1px solid #23252D;"
    >
      <ul role="list" style="list-style: none; margin: 0; padding: 8px 24px 16px;">
        {navItems.map((item) => (
          <li style="border-bottom: 1px solid #1A1C22;">
            <a
              href={item.href}
              class="mobile-nav-link font-mono"
              style="display: block; padding: 16px 4px; text-decoration: none; color: #C8C8C0; font-size: 16px; letter-spacing: 0.5px;"
              data-i18n={item.key}
            >
              {t('en', item.key)}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Page content — pt accounts for fixed nav (~64px) + 3px progress bar -->
    <main>
      <slot />
    </main>

    <!--
      Scroll behavior module scripts — bundled by Astro as deferred module scripts.
      They observe the whole-page DOM so they belong in the layout, not individual sections.
      All run after DOMContentLoaded (module scripts are deferred by default).
    -->
    <script>
      import { initScrollProgress } from '../lib/dom/scrollProgress';
      import { initReveals } from '../lib/dom/reveals';
      import { initCountUp } from '../lib/dom/countUp';
      import { initActiveNav } from '../lib/dom/activeNav';
      import { initSectionSnap } from '../lib/dom/sectionSnap';

      // Note: initI18n() is called by LangToggle.astro which loads on every page.
      // Calling it here again would create a duplicate $lang subscriber and double
      // the querySelectorAll swap (harmless but wasteful). Keep the single call in
      // LangToggle so the i18n module is co-located with the toggle that drives it.
      initScrollProgress();
      initReveals();
      initCountUp();
      initActiveNav();
      initSectionSnap();

      // ── Mobile menu toggle ──────────────────────────────────────────────
      const navToggle = document.getElementById('nav-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const navToggleIcon = document.getElementById('nav-toggle-icon');
      if (navToggle && mobileMenu) {
        const setOpen = (open: boolean) => {
          mobileMenu.hidden = !open;
          navToggle.setAttribute('aria-expanded', String(open));
          if (navToggleIcon) navToggleIcon.textContent = open ? '✕' : '☰';
        };
        navToggle.addEventListener('click', () => setOpen(mobileMenu.hidden));
        // Tapping a link navigates and closes the menu.
        mobileMenu.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => setOpen(false))
        );
        // Esc closes it; resizing up to desktop clears the open state.
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });
        window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
          if (e.matches) setOpen(false);
        });
      }
    </script>
  </body>
</html>
