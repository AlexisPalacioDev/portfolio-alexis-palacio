---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';
import LangToggle from '../components/islands/LangToggle.astro';
import { t } from '../lib/i18n/store';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alexis Palacio — AI Engineer & Full-Stack Developer',
  description = 'AI orchestration, full-stack development, and automation. Available for remote work and freelance.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      No-FOUC: read persisted lang from localStorage before first paint
      and set html[lang] + data-lang so apply.ts can swap on load.
      $lang (persistentAtom) uses the key 'lang' — must match here.
    -->
    <script is:inline>
      (function () {
        try {
          var lang = localStorage.getItem('lang');
          if (lang === 'es') {
            document.documentElement.lang = 'es';
            document.documentElement.setAttribute('data-lang', 'es');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="bg-bg text-ink font-display" style="-webkit-font-smoothing: antialiased; overflow-x: hidden;">

    <!--
      3px lime scroll-progress bar — positioned at the absolute top of the viewport.
      Width is driven by scroll position; the RAF behavior is wired in WU-4 (scrollProgress.ts).
      The DOM element ships here so it exists in the initial HTML before hydration.
    -->
    <div
      id="scroll-progress"
      aria-hidden="true"
      style="position: fixed; top: 0; left: 0; height: 3px; width: 0%; background: #C6F24E; z-index: 60; box-shadow: 0 0 10px rgba(198,242,78,0.7); pointer-events: none;"
    ></div>

    <!-- Fixed navigation bar -->
    <nav
      class="fixed left-0 right-0 z-50 flex items-center justify-between"
      style="top: 3px; padding: 14px 34px; background: rgba(12,13,16,0.78); backdrop-filter: blur(12px); border-bottom: 1px solid #23252D;"
      aria-label="Primary navigation"
    >
      <!-- AP monogram + logotype -->
      <a
        href="#home"
        style="display: flex; align-items: center; gap: 12px; text-decoration: none;"
        aria-label="Alexis Palacio — back to top"
      >
        <span
          class="font-mono font-bold text-bg bg-lime"
          style="display: grid; place-items: center; width: 38px; height: 38px; font-size: 17px; box-shadow: 3px 3px 0 #3D5BFF; letter-spacing: -0.5px;"
        >
          AP
        </span>
        <span
          class="font-mono text-muted hidden md:block"
          style="font-size: 12px; font-weight: 500; letter-spacing: 1px; line-height: 1.4;"
        >
          ALEXIS<br />PALACIO
        </span>
      </a>

      <!-- Nav anchor links -->
      <ul
        class="hidden md:flex items-center gap-6 font-mono"
        style="font-size: 12.5px; letter-spacing: 0.4px; color: #93938B;"
        role="list"
      >
        <li>
          <a
            href="#about"
            class="nav-link hover:text-lime"
            style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
            data-i18n="nav_about"
          >
            {t('en', 'nav_about')}
          </a>
        </li>
        <li>
          <a
            href="#skills"
            class="nav-link hover:text-lime"
            style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
            data-i18n="nav_skills"
          >
            {t('en', 'nav_skills')}
          </a>
        </li>
        <li>
          <a
            href="#projects"
            class="nav-link hover:text-lime"
            style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
            data-i18n="nav_projects"
          >
            {t('en', 'nav_projects')}
          </a>
        </li>
        <li>
          <a
            href="#services"
            class="nav-link hover:text-lime"
            style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
            data-i18n="nav_services"
          >
            {t('en', 'nav_services')}
          </a>
        </li>
        <li>
          <a
            href="#contact"
            class="nav-link hover:text-lime"
            style="opacity: 0.7; transition: color .22s ease, opacity .22s ease; text-decoration: none; color: inherit;"
            data-i18n="nav_contact"
          >
            {t('en', 'nav_contact')}
          </a>
        </li>
      </ul>

      <!-- Language toggle — no framework directive needed; Astro .astro scripts bundle automatically -->
      <LangToggle />
    </nav>

    <!-- Page content — pt accounts for fixed nav (~64px) + 3px progress bar -->
    <div class="pt-[67px]">
      <slot />
    </div>

    <!--
      Scroll behavior module scripts — bundled by Astro as deferred module scripts.
      They observe the whole-page DOM so they belong in the layout, not individual sections.
      All run after DOMContentLoaded (module scripts are deferred by default).
    -->
    <script>
      import { initScrollProgress } from '../lib/dom/scrollProgress';
      import { initReveals } from '../lib/dom/reveals';
      import { initCountUp } from '../lib/dom/countUp';
      import { initActiveNav } from '../lib/dom/activeNav';

      // Note: initI18n() is called by LangToggle.astro which loads on every page.
      // Calling it here again would create a duplicate $lang subscriber and double
      // the querySelectorAll swap (harmless but wasteful). Keep the single call in
      // LangToggle so the i18n module is co-located with the toggle that drives it.
      initScrollProgress();
      initReveals();
      initCountUp();
      initActiveNav();
    </script>
  </body>
</html>
