---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Stack from '../components/sections/Stack.astro';
import Work from '../components/sections/Work.astro';
import Services from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/sections/Footer.astro';
---

<BaseLayout
  title="Alexis Palacio — AI Engineer & Full-Stack Developer"
  description="AI orchestration, automation and full-stack development. 5+ years shipping products in production. Available for remote work and freelance."
>
  <!--
    Sections compose in scroll order:
    #home → marquee → #about → #skills → #projects → #services → #testimonials → #contact → footer
  -->
  <Hero />
  <About />
  <Stack />
  <Work />
  <Services />
  <Testimonials />
  <Contact />
  <Footer />
</BaseLayout>
